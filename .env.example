# Public browser-safe configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://victoriosa.click
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Server-only configuration. Keep values empty in Git.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STAGING_URL=
SUPABASE_STAGING_ANON_KEY=
ALLOWED_ORIGINS=http://localhost:3000

# Permanent production safety defaults
ENABLE_LIVE_PAYMENTS=false
ENABLE_AI_AUTOMATION=false
ENABLE_AUTO_PUBLICATION=false
PAYPAL_ENV=sandbox

# Autopilot Phase 1 safety flags. Prefer these over legacy ENABLE_* switches.
AUTOPILOT_ENABLED=true
AUTOPILOT_AI_ENABLED=false
AUTOPILOT_LIVE_CONNECTORS_ENABLED=false
AUTOPILOT_AUTO_PUBLISH_ENABLED=false
AUTOPILOT_REAL_FULFILLMENT_ENABLED=false
AUTOPILOT_SUPPLIER_PURCHASE_ENABLED=false
AUTOPILOT_OUTBOUND_EMAIL_ENABLED=false
AUTOPILOT_KBEAUTY_SEED_WRITE=false

# Optional sandbox providers
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
AFFILIATE_SIGNING_SECRET=
CRON_SHARED_SECRET=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Commerce defaults
DEFAULT_CURRENCY=UYU
BASE_SOURCE_CURRENCY=USD
DEFAULT_MARGIN_PERCENT=55
MIN_MARGIN_PERCENT=25
RISK_BUFFER_PERCENT=8
